<%- include('partials/head', { title: 'Early access' }) %>
<%- include('partials/nav') %>

<div class="page">
<section class="page-section waitlist" style="min-height:80vh;display:flex;align-items:center;">
  <div class="wrap" style="width:100%;">
    <div class="waitlist-inner">
      <div class="a-fade-up">
        <div class="section-tag">Your estimate</div>
        <h2>What are auto-renewals costing you?</h2>
        <p class="section-sub">Based on UK averages from FCA and CMA data, here's what the typical household overpays. Adjust the sliders to match your situation.</p>

        <div class="calc-panel">
          <div class="calc-slider-row">
            <div class="calc-label-row">
              <span class="calc-label">Insurance policies</span>
              <span class="calc-val" id="calcInsurance">2</span>
            </div>
            <input type="range" class="calc-slider" id="sliderInsurance" min="0" max="8" value="2" step="1">
            <div class="calc-range-labels"><span>0</span><span>8+</span></div>
          </div>

          <div class="calc-slider-row">
            <div class="calc-label-row">
              <span class="calc-label">Subscriptions (streaming, SaaS, gym, apps)</span>
              <span class="calc-val" id="calcSubs">6</span>
            </div>
            <input type="range" class="calc-slider" id="sliderSubs" min="0" max="20" value="6" step="1">
            <div class="calc-range-labels"><span>0</span><span>20+</span></div>
          </div>

          <div class="calc-slider-row">
            <div class="calc-label-row">
              <span class="calc-label">Broadband, mobile &amp; utility contracts</span>
              <span class="calc-val" id="calcUtilities">2</span>
            </div>
            <input type="range" class="calc-slider" id="sliderUtilities" min="0" max="6" value="2" step="1">
            <div class="calc-range-labels"><span>0</span><span>6+</span></div>
          </div>

          <div class="calc-slider-row">
            <div class="calc-label-row">
              <span class="calc-label">Domains &amp; annual services</span>
              <span class="calc-val" id="calcDomains">3</span>
            </div>
            <input type="range" class="calc-slider" id="sliderDomains" min="0" max="10" value="3" step="1">
            <div class="calc-range-labels"><span>0</span><span>10+</span></div>
          </div>

          <div class="calc-total">
            <div class="calc-total-label">Estimated annual exposure</div>
            <div class="calc-total-amount" id="calcTotal">£650</div>
            <div class="calc-total-note">Based on average loyalty penalties across UK markets</div>
          </div>

          <button class="calc-cta" onclick="document.getElementById('calcFormSection').scrollIntoView({behavior:'smooth'})">
            Get your full breakdown →
          </button>
        </div>
      </div>

      <div class="a-fade-up" id="calcFormSection">
        <div class="form-panel">
          <div class="waitlist-urgency">Limited early access</div>
          <div class="calc-context" id="calcContext">Based on your estimate, you could be overpaying <strong>£650</strong> per year. perch. catches that.</div>
          <p class="form-guide">Enter your details and we'll send you a full breakdown of what perch. would track for you — plus early access when it's ready.</p>
          <form id="waitlistForm">
            <input type="hidden" id="estimatedExposure" name="estimated_exposure" value="650">
            <div class="field">
              <label for="name">Name</label>
              <input type="text" id="name" required placeholder="Your name" autocomplete="name">
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" required placeholder="you@email.com" autocomplete="email">
            </div>
            <div class="field">
              <label>I'm signing up as a...</label>
              <div class="segment-row">
                <div class="segment-btn active" data-segment="household">Household</div>
                <div class="segment-btn" data-segment="business">Small business</div>
              </div>
            </div>
            <button type="submit" class="submit-btn">Get my breakdown &amp; join the waitlist</button>
          </form>
          <p class="submit-note">We'll send you one email with your personalised breakdown. No spam, no newsletters, no inbox clutter.</p>
          <div class="form-success" id="formSuccess">
            <div class="check">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10.5L8 14.5L16 5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>You're on the list.</h3>
            <p>We'll email your personalised breakdown when perch. opens up for your segment. In the meantime, start gathering those renewal emails.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</div>

<script>
  let selectedSegment = 'household';
  document.querySelectorAll('.segment-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.segment-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedSegment = btn.getAttribute('data-segment');
    });
  });

  const RATES = { insurance: 75, subs: 180, utilities: 120, domains: 40 };

  function calcTotal(){
    const ins = parseInt(document.getElementById('sliderInsurance').value, 10);
    const subs = parseInt(document.getElementById('sliderSubs').value, 10);
    const util = parseInt(document.getElementById('sliderUtilities').value, 10);
    const dom = parseInt(document.getElementById('sliderDomains').value, 10);

    const total = ins * RATES.insurance + subs * RATES.subs + util * RATES.utilities + dom * RATES.domains;

    document.getElementById('calcInsurance').textContent = ins;
    document.getElementById('calcSubs').textContent = subs;
    document.getElementById('calcUtilities').textContent = util;
    document.getElementById('calcDomains').textContent = dom;

    const formatted = '£' + total.toLocaleString();
    document.getElementById('calcTotal').textContent = formatted;
    document.getElementById('calcContext').innerHTML = 'Based on your estimate, you could be overpaying <strong>' + formatted + '</strong> per year. perch. catches that.';
    document.getElementById('estimatedExposure').value = total;
  }

  document.querySelectorAll('.calc-slider').forEach(s => {
    s.addEventListener('input', calcTotal);
  });

  calcTotal();
</script>
<%- include('partials/footer') %>
