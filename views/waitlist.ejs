<%- include('partials/head', { title: 'early access' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
  <div class="wrap" style="padding-top:140px;padding-bottom:80px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">
    <div>
      <div class="eyebrow">early access</div>
      <h1 style="max-width:none;">you're minutes away from <em>seeing clearly.</em></h1>
      <p style="font-size:15px;color:var(--pencil);line-height:1.6;margin-bottom:24px;">one form, no commitment. we'll email you when perch. opens for your segment. zero spam, zero follow-ups until we're ready.</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div style="font-family:var(--body-serif);font-size:13px;color:var(--dust);">no bank linking required</div>
        <div style="font-family:var(--body-serif);font-size:13px;color:var(--dust);">data stays with your bank</div>
        <div style="font-family:var(--body-serif);font-size:13px;color:var(--dust);">cancel any time, no questions</div>
      </div>
    </div>

    <div>
      <form id="waitlistForm" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" id="estimatedExposure" name="estimated_exposure" value="0">
        <div>
          <label for="name" style="display:block;font-family:var(--mono);font-size:10px;color:var(--dust);margin-bottom:4px;">your name</label>
          <input type="text" id="name" required placeholder="e.g. jo milner" autocomplete="name" style="width:100%;padding:12px 16px;border:1px solid var(--fog);background:var(--slate);color:var(--paper);font-family:var(--sans);font-size:13px;outline:none;border-radius:6px;">
        </div>
        <div>
          <label for="email" style="display:block;font-family:var(--mono);font-size:10px;color:var(--dust);margin-bottom:4px;">email address</label>
          <input type="email" id="email" required placeholder="you@email.com" autocomplete="email" style="width:100%;padding:12px 16px;border:1px solid var(--fog);background:var(--slate);color:var(--paper);font-family:var(--sans);font-size:13px;outline:none;border-radius:6px;">
        </div>
        <div>
          <label style="display:block;font-family:var(--mono);font-size:10px;color:var(--dust);margin-bottom:6px;">i'm signing up as...</label>
          <div style="display:flex;gap:8px;">
            <button type="button" class="ob-segment-pill selected" data-segment="household" style="flex:1;padding:10px;border:1px solid var(--ember);background:var(--ember-soft);color:var(--ember);font-family:var(--sans);font-size:12px;cursor:pointer;border-radius:var(--radius-full);text-align:center;">household</button>
            <button type="button" class="ob-segment-pill" data-segment="freelancer" style="flex:1;padding:10px;border:1px solid var(--fog);background:transparent;color:var(--pencil);font-family:var(--sans);font-size:12px;cursor:pointer;border-radius:var(--radius-full);text-align:center;">freelancer</button>
            <button type="button" class="ob-segment-pill" data-segment="business" style="flex:1;padding:10px;border:1px solid var(--fog);background:transparent;color:var(--pencil);font-family:var(--sans);font-size:12px;cursor:pointer;border-radius:var(--radius-full);text-align:center;">business</button>
          </div>
        </div>
        <button type="submit" style="padding:14px 24px;background:var(--ember);color:var(--obsidian);border:none;border-radius:var(--radius-full);font-family:var(--sans);font-size:13px;font-weight:500;cursor:pointer;margin-top:4px;">join the waitlist &rarr;</button>
        <p style="font-size:11px;color:var(--dust);text-align:center;">no spam. no newsletters. silence until we're ready for you.</p>
      </form>
      <div class="form-success" id="formSuccess">
        <div class="check">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10.5L8 14.5L16 5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>you're on the list.</h3>
        <p id="formSuccessMsg">we'll email you when perch. opens for your segment. start gathering those renewal emails.</p>
      </div>
    </div>
  </div>
</div>

<script>
  var selectedSegment = 'household';

  document.querySelectorAll('.ob-segment-pill').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('.ob-segment-pill').forEach(function(p) {
        p.classList.remove('selected');
        p.style.borderColor = 'var(--fog)';
        p.style.background = 'transparent';
        p.style.color = 'var(--pencil)';
      });
      pill.classList.add('selected');
      pill.style.borderColor = 'var(--ember)';
      pill.style.background = 'var(--ember-soft)';
      pill.style.color = 'var(--ember)';
      selectedSegment = pill.getAttribute('data-segment');
    });
  });

  var form = document.getElementById('waitlistForm');
  var formSuccess = document.getElementById('formSuccess');
  if (form && formSuccess) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var name = document.getElementById('name').value.trim();
      var email = document.getElementById('email').value.trim();
      if (!name || !email) return;

      var msgEl = document.getElementById('formSuccessMsg');
      msgEl.textContent = 'we\'ll email you at ' + email + ' when perch. opens for ' + (selectedSegment === 'business' ? 'small businesses' : selectedSegment === 'freelancer' ? 'freelancers' : 'households') + '. start gathering those renewal emails.';

      try {
        await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, email: email, segment: selectedSegment })
        });
      } catch (_) {}

      form.style.display = 'none';
      formSuccess.classList.add('show');
    });
  }
</script>
<%- include('partials/footer') %>
