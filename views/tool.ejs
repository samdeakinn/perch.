          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="82" onchange="calcTool()"><span class="tool-item-name">admiral</span><span class="tool-item-rate">+£82/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="95" onchange="calcTool()"><span class="tool-item-name">direct line</span><span class="tool-item-rate">+£95/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="78" onchange="calcTool()"><span class="tool-item-name">aviva</span><span class="tool-item-rate">+£78/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="88" onchange="calcTool()"><span class="tool-item-name">churchill</span><span class="tool-item-rate">+£88/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="72" onchange="calcTool()"><span class="tool-item-name">lv=</span><span class="tool-item-rate">+£72/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="69" onchange="calcTool()"><span class="tool-item-name">more than</span><span class="tool-item-rate">+£69/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="ins" data-rate="65" onchange="calcTool()"><span class="tool-item-name">hastings direct</span><span class="tool-item-rate">+£65/yr</span></label>
        </div>
      </div>

      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
          <span>home insurance</span>
          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="home" data-rate="112" onchange="calcTool()"><span class="tool-item-name">direct line</span><span class="tool-item-rate">+£112/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="home" data-rate="96" onchange="calcTool()"><span class="tool-item-name">aviva</span><span class="tool-item-rate">+£96/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="home" data-rate="78" onchange="calcTool()"><span class="tool-item-name">halifax</span><span class="tool-item-rate">+£78/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="home" data-rate="134" onchange="calcTool()"><span class="tool-item-name">churchill</span><span class="tool-item-rate">+£134/yr</span></label>
        </div>
      </div>

      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
          <span>broadband &amp; mobile</span>
          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="144" onchange="calcTool()"><span class="tool-item-name">virgin media</span><span class="tool-item-rate">+£144/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="108" onchange="calcTool()"><span class="tool-item-name">bt</span><span class="tool-item-rate">+£108/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="96" onchange="calcTool()"><span class="tool-item-name">sky</span><span class="tool-item-rate">+£96/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="84" onchange="calcTool()"><span class="tool-item-name">ee</span><span class="tool-item-rate">+£84/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="120" onchange="calcTool()"><span class="tool-item-name">vodafone</span><span class="tool-item-rate">+£120/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="60" onchange="calcTool()"><span class="tool-item-name">plusnet</span><span class="tool-item-rate">+£60/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="bb" data-rate="72" onchange="calcTool()"><span class="tool-item-name">three mobile</span><span class="tool-item-rate">+£72/yr</span></label>
        </div>
      </div>

      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
          <span>subscriptions</span>
          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="sub" data-rate="180" onchange="calcTool()"><span class="tool-item-name">streaming (2+ services)</span><span class="tool-item-rate">+£180/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="sub" data-rate="240" onchange="calcTool()"><span class="tool-item-name">saas tools (3+)</span><span class="tool-item-rate">+£240/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="sub" data-rate="96" onchange="calcTool()"><span class="tool-item-name">gym membership</span><span class="tool-item-rate">+£96/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="sub" data-rate="60" onchange="calcTool()"><span class="tool-item-name">app subscriptions</span><span class="tool-item-rate">+£60/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="sub" data-rate="48" onchange="calcTool()"><span class="tool-item-name">magazine / newsletter</span><span class="tool-item-rate">+£48/yr</span></label>
        </div>
      </div>

      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
          <span>domains &amp; hosting</span>
          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="dom" data-rate="40" onchange="calcTool()"><span class="tool-item-name">1–2 domains</span><span class="tool-item-rate">+£40/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="dom" data-rate="120" onchange="calcTool()"><span class="tool-item-name">3–5 domains</span><span class="tool-item-rate">+£120/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="dom" data-rate="300" onchange="calcTool()"><span class="tool-item-name">5+ domains</span><span class="tool-item-rate">+£300/yr</span></label>
        </div>
      </div>

      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
          <span>software &amp; business</span>
          <span class="tool-cat-arrow">▾</span>
        </div>
        <div class="tool-cat-body">
          <label class="tool-item"><input type="checkbox" data-cat="biz" data-rate="360" onchange="calcTool()"><span class="tool-item-name">accounting software</span><span class="tool-item-rate">+£360/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="biz" data-rate="240" onchange="calcTool()"><span class="tool-item-name">crm / sales tools</span><span class="tool-item-rate">+£240/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="biz" data-rate="480" onchange="calcTool()"><span class="tool-item-name">design tools (adobe, figma)</span><span class="tool-item-rate">+£480/yr</span></label>
          <label class="tool-item"><input type="checkbox" data-cat="biz" data-rate="180" onchange="calcTool()"><span class="tool-item-name">hosting / servers</span><span class="tool-item-rate">+£180/yr</span></label>
        </div>
      </div>
    </div>

    <div class="tool-total a-fade-up" id="toolTotal">
      <div class="tool-total-label">your estimated annual overpayment</div>
      <div class="tool-total-amount" id="toolAmount">£0</div>
      <div class="tool-total-bar">
        <div class="tool-bar-track">
          <div class="tool-bar-fill" id="toolBarFill"></div>
        </div>
        <div class="tool-bar-labels">
          <span>£0</span>
          <span id="toolBarMax">£2,500</span>
        </div>
      </div>
      <div class="tool-total-save" id="toolSaveMsg" style="display:none;">perch. could help you recover <span id="toolSaveAmount">£0</span> of this — just by tracking renewal dates and price changes.</div>
      <div class="tool-total-note">this is what the loyalty penalty costs you each year — money you could keep by switching or renegotiating. perch. tracks every renewal so you never miss the window.</div>
      <a href="/waitlist" class="btn-primary" style="margin-top:20px;display:inline-flex;">get early access →</a>
    </div>
  </div>
</section>
</div>

<script>
function toggleCat(header) {
  var body = header.nextElementSibling;
  var arrow = header.querySelector('.tool-cat-arrow');
  body.classList.toggle('open');
  arrow.textContent = body.classList.contains('open') ? '\u25B4' : '\u25BE';
}
function calcTool() {
  var total = 0;
  document.querySelectorAll('.tool-item input:checked').forEach(function(cb) {
    total += parseInt(cb.getAttribute('data-rate'), 10);
  });
  document.getElementById('toolAmount').textContent = '\u00A3' + total.toLocaleString();
  var max = 2500;
  var pct = Math.min(total / max * 100, 100);
  document.getElementById('toolBarFill').style.width = pct + '%';
  var saveMsg = document.getElementById('toolSaveMsg');
  var saveAmt = document.getElementById('toolSaveAmount');
  if (total > 0) {
    var save = Math.round(total * 0.68);
    saveAmt.textContent = '\u00A3' + save.toLocaleString();
    saveMsg.style.display = 'block';
  } else {
    saveMsg.style.display = 'none';
  }
}
var PRESETS = {
  individual: ['ins-admiral', 'bb-virgin', 'sub-gym', 'dom-1'],
  couple: ['ins-admiral', 'ins-lv', 'home-aviva', 'bb-virgin', 'bb-three', 'sub-stream', 'sub-gym', 'dom-1'],
  business: ['ins-admiral', 'home-direct', 'bb-bt', 'biz-acct', 'biz-crm', 'biz-host', 'dom-3']
};
function applyPreset(name) {
  document.querySelectorAll('.tool-item input').forEach(function(cb) { cb.checked = false; });
  if (name === 'clear') { calcTool(); return; }
  var ids = PRESETS[name] || [];
  ids.forEach(function(id) {
    var parts = id.split('-');
    var cat = parts[0];
    var namePart = parts.slice(1).join('-');
    document.querySelectorAll('.tool-item').forEach(function(item) {
      var text = item.querySelector('.tool-item-name');
      if (text && text.textContent.trim().toLowerCase().indexOf(namePart) >= 0) {
        var cb = item.querySelector('input');
        if (cb) { cb.checked = true; }
      }
    });
  });
  calcTool();
}
document.querySelectorAll('.tool-cat').forEach(function(c) {
  c.querySelector('.tool-cat-body').classList.add('open');
  c.querySelector('.tool-cat-arrow').textContent = '\u25B4';
});
calcTool();
</script>
