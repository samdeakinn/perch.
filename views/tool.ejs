      <button class="tool-preset-btn" data-preset="couple" onclick="applyPreset('couple')">couple / family</button>
      <button class="tool-preset-btn" data-preset="business" onclick="applyPreset('business')">small business</button>
      <button class="tool-preset-btn" data-preset="clear" onclick="applyPreset('clear')">clear all</button>
    </div>

    <div class="tool-categories a-fade-up">
      <div class="tool-cat">
        <div class="tool-cat-header" onclick="toggleCat(this)">
