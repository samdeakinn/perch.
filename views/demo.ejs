<%- include('partials/head', { title: 'demo', metaDesc: 'try perch. in your browser — see how renewal emails get parsed into verdicts in real time.' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">

<section class="demo-page" id="demoPage">
  <div class="wrap" style="text-align:center;padding-top:140px;padding-bottom:20px;">
    <div class="eyebrow" style="justify-content:center;">interactive demo</div>
    <h1 style="max-width:none;margin-bottom:8px;">see perch. <em>in action.</em></h1>
    <p class="demo-intro-text">forward an email in your head. watch what happens. no download, no sign-up, no risk.</p>
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:32px;flex-wrap:wrap;">
      <button class="btn-tertiary" id="demoReplayBtn">&#8635; replay scan</button>
      <span style="display:inline-block;font-size:11px;color:var(--dust);" id="demoStatusBadge">loading your demo...</span>
    </div>
  </div>

  <div class="wrap" style="position:relative;">
    <div class="demo-app" id="demoApp">
      <div class="demo-scanning demo-scanning-active" id="demoScanning">
        <div class="demo-scan-inner">
          <div class="demo-scan-ring"></div>
          <div class="demo-scan-label" id="demoScanLabel">connecting to inbox...</div>
          <div class="demo-scan-track"><div class="demo-scan-fill" id="demoScanFill"></div></div>
        </div>
      </div>

      <div class="demo-summary" id="demoSummary">
        <div class="demo-summary-item"><span class="demo-summary-val" id="demoSumAnnual">£0</span><span class="demo-summary-lbl">annual exposure</span></div>
        <div class="demo-summary-gap"></div>
        <div class="demo-summary-item"><span class="demo-summary-val" id="demoSumItems">0</span><span class="demo-summary-lbl">items tracked</span></div>
        <div class="demo-summary-gap"></div>
        <div class="demo-summary-item"><span class="demo-summary-val" id="demoSumAction">0</span><span class="demo-summary-lbl">need attention</span></div>
      </div>

      <div class="demo-tabs">
        <button class="demo-tab demo-tab-active" data-tab="inbox">inbox</button>
        <button class="demo-tab" data-tab="digest">digest</button>
        <button class="demo-tab" data-tab="savings">savings</button>
      </div>

      <div class="demo-pane demo-pane-active" id="demoPaneInbox">
        <div class="demo-list" id="demoList">
          <div class="demo-item demo-item-init" data-index="0">
            <div class="demo-item-header"><div class="demo-item-icon">🛡️</div><div class="demo-item-body"><div class="demo-item-subject">your policy renews soon</div><div class="demo-item-provider">admiral car insurance</div></div><span class="demo-item-tag">pdf</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£612.40/yr</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">14 aug 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value demo-data-change">+22%</span></div><div class="demo-data-verdict verdict-renegotiate">renegotiate — price up 22% — loyalty penalty applied.</div></div></div>
          </div>
          <div class="demo-item demo-item-init" data-index="1">
            <div class="demo-item-header"><div class="demo-item-icon">🎬</div><div class="demo-item-body"><div class="demo-item-subject">your subscription ends</div><div class="demo-item-provider">adobe creative cloud</div></div><span class="demo-item-tag">invoice</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£59.99/mo</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">3 sep 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value">no change</span></div><div class="demo-data-verdict verdict-cancel">cancel — unused for 4 months. last login: march 2026.</div></div></div>
          </div>
          <div class="demo-item demo-item-init" data-index="2">
            <div class="demo-item-header"><div class="demo-item-icon">🌐</div><div class="demo-item-body"><div class="demo-item-subject">your broadband price is changing</div><div class="demo-item-provider">virgin media broadband</div></div><span class="demo-item-tag">notice</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£42.00/mo</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">21 jul 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value demo-data-change">+£14/mo</span></div><div class="demo-data-verdict verdict-renegotiate">renegotiate — out of contract pricing. switch or renegotiate.</div></div></div>
          </div>
          <div class="demo-item demo-item-init" data-index="3">
            <div class="demo-item-header"><div class="demo-item-icon">🔗</div><div class="demo-item-body"><div class="demo-item-subject">domain renewal reminder</div><div class="demo-item-provider">namecheap — perch. domain</div></div><span class="demo-item-tag">reminder</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£14.99/yr</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">18 aug 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value">no change</span></div><div class="demo-data-verdict verdict-renew">renew — essential domain. price unchanged.</div></div></div>
          </div>
          <div class="demo-item demo-item-init" data-index="4">
            <div class="demo-item-header"><div class="demo-item-icon">🎬</div><div class="demo-item-body"><div class="demo-item-subject">monthly membership</div><div class="demo-item-provider">puregym manchester</div></div><span class="demo-item-tag">invoice</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£32.00/mo</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">1 aug 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value">no change</span></div><div class="demo-data-verdict verdict-cancel">cancel — unused since march. £160/yr saved by cancelling.</div></div></div>
          </div>
          <div class="demo-item demo-item-init" data-index="5">
            <div class="demo-item-header"><div class="demo-item-icon">🛡️</div><div class="demo-item-body"><div class="demo-item-subject">your home insurance renews</div><div class="demo-item-provider">direct line home insurance</div></div><span class="demo-item-tag">pdf</span></div>
            <div class="demo-item-data"><div class="demo-item-data-inner"><div class="demo-data-row"><span class="demo-data-label">amount</span><span class="demo-data-value">£387.00/yr</span></div><div class="demo-data-row"><span class="demo-data-label">renews</span><span class="demo-data-value">5 sep 2026</span></div><div class="demo-data-row"><span class="demo-data-label">change</span><span class="demo-data-value demo-data-change">+31%</span></div><div class="demo-data-verdict verdict-renegotiate">renegotiate — massive hike. new customer rate is £289.</div></div></div>
          </div>
        </div>
        <div class="demo-list-footer" id="demoListFooter" style="display:none;">
          <div class="demo-list-footer-inner"><span class="demo-footer-text">all 6 renewals processed</span><button class="demo-list-footer-btn" id="demoViewDigestBtn">view digest →</button></div>
        </div>
      </div>

      <div class="demo-pane" id="demoPaneDigest">
        <div class="demo-digest-pane">
          <div class="demo-digest-pane-header"><span>📬</span><div><div style="font-size:13px;font-weight:600;">weekly renewal roundup</div><div style="font-size:11px;color:var(--dust);">issued mon 14 jul 2026</div></div></div>
          <div class="demo-digest-intro">good morning. here's what's renewing this week and what needs your attention.</div>
          <div class="demo-digest-group"><div class="demo-digest-heading"><span class="demo-dot-urgent"></span> needs action</div>
            <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>admiral car insurance</span><span class="demo-digest-meta">£612.40/yr · ⬆ 22%</span></div>
            <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>virgin media broadband</span><span class="demo-digest-meta">£42/mo · ⬆ +£14/mo</span></div>
            <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>direct line home insurance</span><span class="demo-digest-meta">£387/yr · ⬆ 31%</span></div>
          </div>
          <div class="demo-digest-group"><div class="demo-digest-heading"><span class="demo-dot-cancel"></span> consider cancelling</div>
            <div class="demo-digest-item"><span class="demo-digest-badge cancel">cancel</span><span>adobe creative cloud</span><span class="demo-digest-meta">£59.99/mo · unused 4mo</span></div>
            <div class="demo-digest-item"><span class="demo-digest-badge cancel">cancel</span><span>puregym manchester</span><span class="demo-digest-meta">£32/mo · unused since mar</span></div>
          </div>
          <div class="demo-digest-group"><div class="demo-digest-heading"><span class="demo-dot-ok"></span> all clear</div>
            <div class="demo-digest-item"><span class="demo-digest-badge ok">renew</span><span>namecheap — perch. domain</span><span class="demo-digest-meta">£14.99/yr</span></div>
          </div>
        </div>
      </div>

      <div class="demo-pane" id="demoPaneSavings">
        <div class="demo-savings-pane">
          <div class="demo-savings-hero-num" id="demoSavingsHero">£0</div>
          <div class="demo-savings-hero-lbl">potential annual savings found</div>
          <div class="demo-savings-detail">
            <div class="demo-savings-row"><span>by renegotiating 3 policies</span><span class="demo-savings-pos">+£328</span></div>
            <div class="demo-savings-row"><span>by cancelling 2 unused subs</span><span class="demo-savings-pos">+£1,103</span></div>
            <div class="demo-savings-row demo-savings-total"><span>total potential savings</span><span>&pound;1,431</span></div>
          </div>
          <p class="demo-savings-note">based on typical loyalty penalties and unused subscription costs. your actual savings will vary.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="wrap" style="text-align:center;padding:48px 0 20px;">
    <div class="demo-scenarios" id="demoScenarios" style="display:none;">
      <div style="font-size:11px;color:var(--dust);margin-bottom:12px;">try clicking around</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;">
        <button class="demo-scenario-btn" data-action="digest">view the digest</button>
        <button class="demo-scenario-btn" data-action="savings">see your savings</button>
        <button class="demo-scenario-btn" data-action="expand">expand an item</button>
        <button class="demo-scenario-btn" data-action="replay">replay the scan</button>
      </div>
    </div>
  </div>

  <div class="wrap" style="text-align:center;padding:60px 0 80px;">
    <h2 style="max-width:none;margin:0 auto 16px;">see what <em>you're</em> missing.</h2>
    <p style="font-size:15px;color:var(--pencil);max-width:420px;margin:0 auto 28px;line-height:1.6;">forward one email. get a date, an amount, and a verdict. that's the whole loop.</p>
    <a href="/waitlist" class="btn-primary">get early access &rarr;</a>
    <p style="font-size:12px;color:var(--dust);margin-top:10px;">no bank linking. no auto-cancel bots. just visibility.</p>
  </div>
</section>

</div>

<script src="/demo.js?v=2"></script>
<%- include('partials/footer') %>
