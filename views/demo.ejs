<%- include('partials/head', { title: 'demo', metaDesc: 'try perch. in your browser — see how renewal emails get parsed into verdicts in real time.' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">

<section class="demo-page" id="demoPage">
  <div class="wrap" style="text-align:center;padding-top:140px;padding-bottom:60px;">
    <div class="eyebrow" style="justify-content:center;">interactive demo</div>
    <h1 style="max-width:none;margin-bottom:12px;">see perch. <em class="glow-text">in action.</em></h1>
    <p style="font-size:16px;color:var(--text-dim);max-width:480px;margin:0 auto 32px;line-height:1.6;">forward an email in your head. watch what happens. no download, no sign-up, no risk.</p>
    <button class="demo-launch-btn" id="demoLaunchBtn">launch the demo →</button>
    <p style="font-size:12px;color:var(--text-faint);margin-top:10px;">everything runs in your browser. nothing is saved.</p>
  </div>

  <!-- macOS-style window -->
  <div class="demo-window" id="demoWindow">
    <div class="demo-titlebar">
      <div class="demo-traffic">
        <span class="demo-dot demo-dot-red"></span>
        <span class="demo-dot demo-dot-yellow"></span>
        <span class="demo-dot demo-dot-green"></span>
      </div>
      <div class="demo-title-text">perch.</div>
    </div>

    <div class="demo-body">
      <!-- Scanning overlay -->
      <div class="demo-scanning" id="demoScanning">
        <div class="demo-scan-inner">
          <div class="demo-scan-icon">
            <div class="demo-scan-ring"></div>
            <span>⌛</span>
          </div>
          <div class="demo-scan-label" id="demoScanLabel">connecting to inbox...</div>
          <div class="demo-scan-track">
            <div class="demo-scan-fill" id="demoScanFill"></div>
          </div>
        </div>
      </div>

      <!-- App content (hidden until scanning done) -->
      <div class="demo-app" id="demoApp">
        <!-- Summary bar -->
        <div class="demo-summary" id="demoSummary">
          <div class="demo-summary-item">
            <span class="demo-summary-val" id="demoSumAnnual">£0</span>
            <span class="demo-summary-lbl">annual exposure</span>
          </div>
          <div class="demo-summary-gap"></div>
          <div class="demo-summary-item">
            <span class="demo-summary-val" id="demoSumItems">0</span>
            <span class="demo-summary-lbl">items tracked</span>
          </div>
          <div class="demo-summary-gap"></div>
          <div class="demo-summary-item">
            <span class="demo-summary-val" id="demoSumAction">0</span>
            <span class="demo-summary-lbl">need attention</span>
          </div>
        </div>

        <!-- Tab bar -->
        <div class="demo-tabs">
          <button class="demo-tab demo-tab-active" data-tab="inbox">inbox</button>
          <button class="demo-tab" data-tab="digest">digest</button>
          <button class="demo-tab" data-tab="savings">savings</button>
        </div>

        <!-- Inbox pane -->
        <div class="demo-pane demo-pane-active" id="demoPaneInbox">
          <div class="demo-list" id="demoList"></div>
          <div class="demo-list-footer" id="demoListFooter" style="display:none;">
            <div class="demo-list-footer-inner">
              <span>all 6 renewals processed</span>
              <button class="demo-list-footer-btn" id="demoViewDigestBtn">view digest →</button>
            </div>
          </div>
        </div>

        <!-- Digest pane -->
        <div class="demo-pane" id="demoPaneDigest">
          <div class="demo-digest-pane">
            <div class="demo-digest-pane-header">
              <span class="demo-digest-pane-icon">📬</span>
              <div>
                <div style="font-size:13px;font-weight:600;">weekly renewal roundup</div>
                <div style="font-size:11px;color:var(--text-faint);">issued mon 14 jul 2026</div>
              </div>
            </div>
            <div class="demo-digest-intro">good morning. here's what's renewing this week and what needs your attention.</div>
            <div class="demo-digest-group">
              <div class="demo-digest-heading"><span class="demo-dot-urgent"></span> needs action</div>
              <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>admiral car insurance</span><span class="demo-digest-meta">£612.40/yr · ⬆ 22%</span><span class="demo-digest-deadline">23 days</span></div>
              <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>virgin media broadband</span><span class="demo-digest-meta">£42/mo · ⬆ +£14/mo</span><span class="demo-digest-deadline">12 days</span></div>
              <div class="demo-digest-item"><span class="demo-digest-badge urgent">renegotiate</span><span>direct line home insurance</span><span class="demo-digest-meta">£387/yr · ⬆ 31%</span><span class="demo-digest-deadline">56 days</span></div>
            </div>
            <div class="demo-digest-group">
              <div class="demo-digest-heading"><span class="demo-dot-cancel"></span> consider cancelling</div>
              <div class="demo-digest-item"><span class="demo-digest-badge cancel">cancel</span><span>adobe creative cloud</span><span class="demo-digest-meta">£59.99/mo · unused 4mo</span><span class="demo-digest-deadline">55 days</span></div>
              <div class="demo-digest-item"><span class="demo-digest-badge cancel">cancel</span><span>puregym manchester</span><span class="demo-digest-meta">£32/mo · unused since mar</span><span class="demo-digest-deadline">23 days</span></div>
            </div>
            <div class="demo-digest-group">
              <div class="demo-digest-heading"><span class="demo-dot-ok"></span> all clear</div>
              <div class="demo-digest-item"><span class="demo-digest-badge ok">renew</span><span>namecheap — perch. domain</span><span class="demo-digest-meta">£14.99/yr</span><span class="demo-digest-deadline">27 days</span></div>
            </div>
          </div>
        </div>

        <!-- Savings pane -->
        <div class="demo-pane" id="demoPaneSavings">
          <div class="demo-savings-pane">
            <div class="demo-savings-hero">
              <div class="demo-savings-hero-num" id="demoSavingsHero">£0</div>
              <div class="demo-savings-hero-lbl">potential annual savings found</div>
            </div>
            <div class="demo-savings-detail">
              <div class="demo-savings-row"><span>by renegotiating 3 policies</span><span class="demo-savings-pos">+£328</span></div>
              <div class="demo-savings-row"><span>by cancelling 2 unused subs</span><span class="demo-savings-pos">+£1,103</span></div>
              <div class="demo-savings-row demo-savings-total"><span>total potential savings</span><span id="demoSavingsTotal">£1,431</span></div>
            </div>
            <p class="demo-savings-note">based on typical loyalty penalties and unused subscription costs. your actual savings will vary.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="wrap" style="text-align:center;padding:80px 0 60px;">
    <h2 style="max-width:none;margin:0 auto 16px;">see what <em class="glow-text">you're</em> missing.</h2>
    <p style="font-size:15px;color:var(--text-dim);max-width:420px;margin:0 auto 28px;line-height:1.6;">forward one email. get a date, an amount, and a verdict. that's the whole loop.</p>
    <a href="/waitlist" class="btn-primary" style="padding:16px 32px;font-size:16px;">get early access →</a>
    <p style="font-size:12px;color:var(--text-faint);margin-top:10px;">no bank linking. no auto-cancel bots. just visibility.</p>
  </div>
</section>

</div>

<script src="/demo.js"></script>
<%- include('partials/footer') %>