<%- include('partials/head', { title: 'resources', metaDesc: 'guides, tools, and calculators to help you understand and reduce your auto-renewal exposure.' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">

<section class="lp-section">
  <div class="wrap" style="text-align:center;padding-top:120px;padding-bottom:32px;">
