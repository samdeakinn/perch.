<%- include('partials/head', { title: article.title + ' — Blog' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="lp-section">
  <div class="wrap" style="max-width:680px;">
    <div class="page-header">
      <div class="eyebrow">blog</div>
      <h2><%= article.title %></h2>
      <div style="font-size:13px;color:var(--dust);margin-top:8px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
        <span><%= article.date %> · <%= article.readTime %> min read</span>
        <button class="article-share-btn" onclick="shareArticle()" title="Copy link">⎘ share</button>
      </div>
    </div>
    <div class="article-body">
      <%- include('articles/' + article.template) %>
    </div>
    <div class="article-footer">
      <div style="font-size:12px;color:var(--dust);margin-bottom:16px;">
        <a href="/blog" style="color:var(--pencil);">blog</a>
        <span style="margin:0 6px;">/</span>
        <span><%= article.title %></span>
      </div>

      <% if (locals.articles) {
        const related = articles.filter(a => a.slug !== article.slug).slice(0, 3);
        if (related.length > 0) { %>
      <div style="margin-bottom:24px;">
        <div style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--dust);margin-bottom:12px;">related articles</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <% related.forEach(r => { %>
          <a href="/blog/<%= r.slug %>" style="display:block;padding:14px 16px;border:1px solid var(--mist);border-radius:3px;transition:border-color .2s var(--ease);">
            <div style="font-size:13px;font-weight:600;color:var(--paper);margin-bottom:4px;"><%= r.title %></div>
            <div style="font-size:11px;color:var(--dust);"><%= r.readTime %> min read</div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } } %>

      <a href="/blog" style="font-size:14px;color:var(--ember);">&larr; back to blog</a>
    </div>

    <%- include('partials/newsletter-cta') %>
  </div>
</section>
</div>
<script>function shareArticle(){
  var url = location.href;
  if (navigator.share) navigator.share({url:url});
  else { navigator.clipboard.writeText(url).then(function() {
    var btn = document.querySelector('.article-share-btn');
    var orig = btn.textContent;
    btn.textContent = '✓ copied';
    setTimeout(function() { btn.textContent = orig; }, 2000);
  }); }
}</script>

<%- include('partials/footer') %>
