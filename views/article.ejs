<%- include('partials/head', { title: article.title + ' — Blog' }) %>
<div class="scroll-progress"><div class="scroll-progress-fill" id="scrollFill"></div></div>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="page-section">
  <div class="wrap" style="max-width:680px;">
    <div class="page-header a-fade-up">
      <div class="section-tag">blog</div>
      <h2><%= article.title %></h2>
      <div style="font-size:13px;color:var(--text-faint);margin-top:8px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
        <span><%= article.date %> · <%= article.readTime %> min read</span>
        <button class="article-share-btn" onclick="shareArticle()" title="Copy link">⎘ share</button>
      </div>
    </div>
    <div class="article-body a-fade-up">
      <%- include('articles/' + article.template) %>
    </div>
    <div class="article-footer a-fade-up">
      <div style="font-size:12px;color:var(--text-faint);margin-bottom:16px;">
        <a href="/blog" style="color:var(--text-dim);">blog</a>
        <span style="margin:0 6px;">/</span>
        <span><%= article.title %></span>
      </div>

      <% if (locals.articles) {
        const related = articles.filter(a => a.slug !== article.slug).slice(0, 3);
        if (related.length > 0) { %>
      <div style="margin-bottom:24px;">
        <div style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-faint);margin-bottom:12px;">related articles</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <% related.forEach(r => { %>
          <a href="/blog/<%= r.slug %>" style="display:block;padding:14px 16px;border:1px solid var(--line);border-radius:var(--radius-sm);transition:border-color .2s var(--ease);">
            <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:4px;"><%= r.title %></div>
            <div style="font-size:11px;color:var(--text-faint);"><%= r.readTime %> min read</div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } } %>

      <a href="/blog" style="font-size:14px;color:var(--accent);">&larr; back to blog</a>
    </div>
  </div>
</section>
</div>
<script>function sharearticle(){
  const url = location.href;
  if (navigator.share) navigator.share({url});
  else { navigator.clipboard.writetext(url).then(() => {
    const btn = document.queryselector('.article-share-btn');
    const orig = btn.textcontent;
    btn.textcontent = '✓ copied';
    settimeout(() => btn.textcontent = orig, 2000);
  }); }
}</script>

<%- include('partials/footer') %>
