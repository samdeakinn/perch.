<%- include('partials/head', { title: 'stats' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="lp-section">
  <div class="wrap" style="max-width:780px;">
    <div class="page-header">
      <div class="eyebrow">stats</div>
      <h2>perch. by the numbers.</h2>
      <p>live waitlist analytics. these numbers update in real-time as people join the list.</p>
    </div>

    <div class="a-fade-up">
      <div class="dash-stats" style="justify-content:center;flex-wrap:wrap;">
        <div class="dash-stat">
          <div class="dash-stat-num"><%= stats.total %></div>
          <div class="dash-stat-label">total signups</div>
        </div>
        <div class="dash-stat-divider"></div>
        <div class="dash-stat">
          <div class="dash-stat-num"><%= stats.households %></div>
          <div class="dash-stat-label">households</div>
        </div>
        <div class="dash-stat-divider"></div>
        <div class="dash-stat">
          <div class="dash-stat-num"><%= stats.businesses %></div>
          <div class="dash-stat-label">small businesses</div>
        </div>
        <div class="dash-stat-divider"></div>
        <div class="dash-stat">
          <div class="dash-stat-num" style="font-size:14px;font-family:var(--sans);font-weight:600;"><%= stats.todaySignups %></div>
          <div class="dash-stat-label">today</div>
        </div>
        <div class="dash-stat-divider"></div>
        <div class="dash-stat">
          <div class="dash-stat-num"><%= stats.totalRefs %></div>
          <div class="dash-stat-label">referrals</div>
        </div>
      </div>
    </div>

    <div class="dash-card a-fade-up">
      <h3 style="margin-bottom:16px;">signups over time</h3>
      <% if (stats.signupsByDay.length > 0) { %>
      <div class="stats-chart" id="statsChart">
        <% 
        const max = Math.max(...stats.signupsByDay.map(d => d.count), 1);
        stats.signupsByDay.forEach(d => {
          const h = Math.round(d.count / max * 120);
        %>
        <div class="stats-bar-wrap" title="<%= d.date %>: <%= d.count %> signups">
          <div class="stats-bar" style="height:<%= h %>px;"></div>
          <div class="stats-bar-label"><%= d.date.slice(5) %></div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p style="font-size:14px;color:var(--text-dim);">no signup data yet. share the waitlist to get things moving.</p>
      <% } %>
    </div>

    <div class="dash-card a-fade-up">
      <div class="stats-meta">
        <div class="stats-meta-item">
          <div class="stats-meta-label">avg. referrals per person</div>
          <div class="stats-meta-val"><%= stats.avgReferralsPerPerson %></div>
        </div>
        <div class="stats-meta-item">
          <div class="stats-meta-label">household / business ratio</div>
          <div class="stats-meta-val"><%= stats.total > 0 ? Math.round(stats.households / stats.total * 100) : 0 %>% / <%= stats.total > 0 ? Math.round(stats.businesses / stats.total * 100) : 0 %>%</div>
        </div>
      </div>
    </div>

    <div class="dash-card a-fade-up" style="text-align:center;">
      <p style="font-size:13px;color:var(--text-dim);margin-bottom:16px;">share the waitlist to grow these numbers.</p>
      <a href="/waitlist" class="btn-primary" style="display:inline-flex;">join the waitlist →</a>
    </div>
  </div>
</section>
</div>

<%- include('partials/footer') %>