<%- include('partials/head', { title: 'Uses' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="page-section">
  <div class="wrap">
    <div class="page-header a-fade-up">
      <div class="section-tag">Uses</div>
      <h2>One tool, four kinds of overwhelm.</h2>
      <p>perch. works the same way for everyone — forward emails, get verdicts — but what you forward and what you catch depends on who you are and what you're juggling.</p>
    </div>

    <div class="uses-nav a-fade-up">
      <a href="#families" class="uses-pill">Families</a>
      <a href="#freelancers" class="uses-pill">Freelancers</a>
      <a href="#startups" class="uses-pill">Startups &amp; agencies</a>
      <a href="#landlords" class="uses-pill">Landlords</a>
    </div>

    <div class="uses-card a-fade-up" id="families">
      <div class="uses-card-header">
        <div class="uses-emoji">🏠</div>
        <div>
          <h3>Households &amp; families</h3>
          <p class="uses-tagline">You didn't sign up to be your family's renewal admin.</p>
        </div>
      </div>
      <div class="uses-grid">
        <div class="uses-detail">
          <div class="uses-subhead">What you forward</div>
          <ul>
            <li>Car and home insurance renewal emails</li>
            <li>Broadband and mobile contract notices</li>
            <li>Pet insurance and life cover renewals</li>
            <li>Gym, streaming, and app subscriptions</li>
            <li>Annual service contracts (boiler, alarm, etc.)</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">What perch. catches</div>
          <ul>
            <li>Insurance hikes of 20–40% you'd miss otherwise</li>
            <li>Children's activity subscriptions you forgot about</li>
            <li>Annual memberships that auto-renew on a card you don't check</li>
            <li>Broadband contracts that've quietly switched to out-of-contract pricing</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">Example verdicts</div>
          <div class="uses-eg">
            <span class="digest-verdict urgent">Renegotiate</span>
            <span>Admiral Car Insurance — £487 → £612 (⬆ 26%)</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict cancel">Cancel</span>
            <span>PureGym — £32/mo, unused since March</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict monitor">Renew</span>
            <span>British Gas HomeCare — £264/yr, price stable</span>
          </div>
        </div>
      </div>
    </div>

    <div class="uses-card a-fade-up" id="freelancers">
      <div class="uses-card-header">
        <div class="uses-emoji">✏️</div>
        <div>
          <h3>Freelancers</h3>
          <p class="uses-tagline">Your toolkit renews whether your invoices get paid or not.</p>
        </div>
      </div>
      <div class="uses-grid">
        <div class="uses-detail">
          <div class="uses-subhead">What you forward</div>
          <ul>
            <li>Creative Cloud, Figma, Notion receipts</li>
            <li>Professional indemnity insurance renewals</li>
            <li>Domain and hosting invoices</li>
            <li>Co-working membership renewals</li>
            <li>Accounting software subs (FreeAgent, Xero)</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">What perch. catches</div>
          <ul>
            <li>SaaS tools you bought for one project and kept paying for</li>
            <li>Insurance you didn't realise had a 14-day notice window</li>
            <li>Domains expiring while you're between projects</li>
            <li>Co-working memberships you stopped using months ago</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">Example verdicts</div>
          <div class="uses-eg">
            <span class="digest-verdict cancel">Cancel</span>
            <span>Figma — £12/mo, no active projects</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict urgent">Renegotiate</span>
            <span>Hiscox PI Insurance — £320, loyalty price up 18%</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict monitor">Monitor</span>
            <span>Namecheap — perch.  domain, renews in 60 days</span>
          </div>
        </div>
      </div>
    </div>

    <div class="uses-card a-fade-up" id="startups">
      <div class="uses-card-header">
        <div class="uses-emoji">⚡</div>
        <div>
          <h3>Startups &amp; small agencies</h3>
          <p class="uses-tagline">Fifteen SaaS tools and no one knows who manages them.</p>
        </div>
      </div>
      <div class="uses-grid">
        <div class="uses-detail">
          <div class="uses-subhead">What you forward</div>
          <ul>
            <li>SaaS receipts from the whole team's tools</li>
            <li>Business insurance and liability renewals</li>
            <li>Domain portfolios and hosting renewals</li>
            <li>Vendor and supplier contract notices</li>
            <li>Annual service agreements (CRM, analytics, etc.)</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">What perch. catches</div>
          <ul>
            <li>SaaS subscriptions from former employees still billing</li>
            <li>Free trials that auto-converted to annual plans</li>
            <li>Insurance policies with overlapping coverage</li>
            <li>Enterprise contract renewals with 30-day notice periods</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">Example verdicts</div>
          <div class="uses-eg">
            <span class="digest-verdict cancel">Cancel</span>
            <span>Intercom — £149/mo, replaced by Crisp 2 months ago</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict urgent">Renegotiate</span>
            <span>HubSpot — £1,800/yr, contract auto-renewed without review</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict monitor">Renew</span>
            <span>GitHub Enterprise — £44/user, team stable at 5</span>
          </div>
        </div>
      </div>
    </div>

    <div class="uses-card a-fade-up" id="landlords">
      <div class="uses-card-header">
        <div class="uses-emoji">🏘️</div>
        <div>
          <h3>Landlords</h3>
          <p class="uses-tagline">Each property has its own set of renewals. They don't synchronise.</p>
        </div>
      </div>
      <div class="uses-grid">
        <div class="uses-detail">
          <div class="uses-subhead">What you forward</div>
          <ul>
            <li>Landlord building insurance renewals</li>
            <li>Gas safety certificate reminders</li>
            <li>EPC renewal notices</li>
            <li>Mortgage product expiry letters</li>
            <li>Management software subscriptions</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">What perch. catches</div>
          <ul>
            <li>Insurance on vacant properties that's higher than it should be</li>
            <li>EPC and gas cert expiries with no built-in reminder</li>
            <li>Mortgage deals ending that you didn't track across properties</li>
            <li>Overlapping or duplicate coverage across portfolios</li>
          </ul>
        </div>
        <div class="uses-detail">
          <div class="uses-subhead">Example verdicts</div>
          <div class="uses-eg">
            <span class="digest-verdict urgent">Renegotiate</span>
            <span>Direct Line Landlord — £387, auto-renewed up 31%</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict cancel">Cancel</span>
            <span>Gas Safety Register reminder — already completed</span>
          </div>
          <div class="uses-eg">
            <span class="digest-verdict monitor">Renew</span>
            <span>EPC certificate — expires Jan 2027, 6 months to go</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</div>

<%- include('partials/footer') %>
