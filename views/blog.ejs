<%- include('partials/head', { title: 'blog' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="lp-section">
  <div class="wrap" style="max-width:780px;">
    <div class="page-header">
      <div class="eyebrow">blog</div>
      <h2>auto-renewal, explained.</h2>
      <p>what the industry doesn't want you to know about the loyalty penalty, subscription traps, and how to stop overpaying without spending your life on the phone to customer service.</p>
    </div>

    <div class="blog-list">
      <% articles.forEach(a => { %>
      <a href="/blog/<%= a.slug %>" class="blog-card">
        <div class="blog-card-meta"><%= a.date %> · <%= a.readTime %> min read</div>
        <h3><%= a.title %></h3>
        <p><%= a.excerpt %></p>
        <div class="blog-card-footer">read more →</div>
      </a>
      <% }) %>
    </div>

    <div class="blog-rss" style="margin-top:32px;">
      <div style="border:1px solid var(--mist);border-radius:4px;padding:28px 24px;background:var(--slate);text-align:center;">
        <div style="font-size:14px;font-weight:600;margin-bottom:6px;">new articles in your inbox</div>
        <div style="font-size:12.5px;color:var(--pencil);margin-bottom:16px;line-height:1.5;">no spam. just the occasional deep dive on auto-renewal, loyalty penalties, and keeping your money where it belongs.</div>
        <form id="blogSubscribe" style="max-width:400px;margin:0 auto;display:flex;gap:8px;">
          <input type="email" id="blogEmail" placeholder="you@email.com" required style="flex:1;padding:10px 14px;border-radius:8px;border:1px solid var(--fog);background:var(--slate);color:var(--paper);font-size:13px;outline:none;font-family:var(--sans);">
          <button type="submit" style="padding:10px 18px;border-radius:8px;border:none;background:var(--ember);color:var(--obsidian);font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;font-family:var(--sans);">subscribe</button>
        </form>
        <div id="blogSubMsg" style="display:none;font-size:13px;color:var(--ember);margin-top:10px;">you're subscribed. no spam, ever.</div>
      </div>
      <div style="margin-top:12px;">
        <a href="/blog/feed.xml" style="font-size:13px;color:var(--dust);">subscribe via rss</a>
      </div>
    </div>

    <%- include('partials/newsletter-cta') %>
  </div>
</section>
</div>

<script>
document.getElementById('blogSubscribe')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  var email = document.getElementById('blogEmail').value.trim();
  if (!email) return;
  try {
    var r = await fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: 'Blog Reader', email: email, segment: 'household', source: 'blog' }) });
    var d = await r.json();
    this.style.display = 'none';
    var msg = document.getElementById('blogSubMsg');
    msg.textContent = d.ok ? (d.existing ? 'you\'re already subscribed.' : 'you\'re subscribed. no spam, ever.') : 'error — try again.';
    msg.style.display = 'block';
  } catch(_) { this.style.display = 'none'; document.getElementById('blogSubMsg').style.display = 'block'; }
});
</script>
<%- include('partials/footer') %>
