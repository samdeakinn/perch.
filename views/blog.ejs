<%- include('partials/head', { title: 'Blog' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">
<section class="page-section">
  <div class="wrap" style="max-width:780px;">
    <div class="page-header a-fade-up">
      <div class="section-tag">Blog</div>
      <h2>Auto-renewal, explained.</h2>
      <p>What the industry doesn't want you to know about the loyalty penalty, subscription traps, and how to stop overpaying without spending your life on the phone to customer service.</p>
    </div>

    <div class="blog-list a-fade-up">
      <% articles.forEach(a => { %>
      <a href="/blog/<%= a.slug %>" class="blog-card">
        <div class="blog-card-meta"><%= a.date %> · <%= a.readTime %> min read</div>
        <h3><%= a.title %></h3>
        <p><%= a.excerpt %></p>
        <div class="blog-card-footer">Read more →</div>
      </a>
      <% }) %>
    </div>

    <div class="blog-rss a-fade-up" style="margin-top:32px;">
      <div style="border:1px solid var(--line);border-radius:var(--radius);padding:28px 24px;background:var(--bg-soft);text-align:center;">
        <div style="font-size:14px;font-weight:600;margin-bottom:6px;">New articles in your inbox</div>
        <div style="font-size:12.5px;color:var(--text-dim);margin-bottom:16px;line-height:1.5;">No spam. Just the occasional deep dive on auto-renewal, loyalty penalties, and keeping your money where it belongs.</div>
        <form id="blogSubscribe" style="max-width:400px;margin:0 auto;display:flex;gap:8px;">
          <input type="email" id="blogEmail" placeholder="you@email.com" required style="flex:1;padding:10px 14px;border-radius:8px;border:1px solid var(--line-strong);background:var(--bg);color:var(--text);font-size:13px;outline:none;font-family:var(--sans);">
          <button type="submit" style="padding:10px 18px;border-radius:8px;border:none;background:var(--accent);color:#181208;font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;font-family:var(--sans);">Subscribe</button>
        </form>
        <div id="blogSubMsg" style="display:none;font-size:13px;color:var(--accent);margin-top:10px;">You're subscribed. No spam, ever.</div>
      </div>
      <div style="margin-top:12px;">
        <a href="/blog/feed.xml" style="font-size:13px;color:var(--text-faint);">Subscribe via RSS</a>
      </div>
    </div>
  </div>
</section>
</div>

<script>
document.getElementById('blogSubscribe')?.addEventListener('submit', e => {
  e.preventDefault();
  document.getElementById('blogSubscribe').style.display = 'none';
  document.getElementById('blogSubMsg').style.display = 'block';
});
</script>
<%- include('partials/footer') %>
