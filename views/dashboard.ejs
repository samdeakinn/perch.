          </div>
        </div>
      </div>

      <div class="dash-card" style="margin-top:24px;">
        <div class="dash-card-header">recent activity</div>
        <div class="dash-activity">
          <div class="dash-activity-item">
            <div class="dash-activity-icon">📬</div>
            <div class="dash-activity-body"><strong>Adobe Creative Cloud</strong> — renewal notice received</div>
            <span class="dash-activity-time">2h ago</span>
          </div>
          <div class="dash-activity-item">
            <div class="dash-activity-icon">💰</div>
            <div class="dash-activity-body"><strong>Virgin Media</strong> — saved £168/yr by renegotiating</div>
            <span class="dash-activity-time">1d ago</span>
          </div>
          <div class="dash-activity-item">
            <div class="dash-activity-icon">✅</div>
            <div class="dash-activity-body"><strong>Direct Line</strong> — switched provider, saved £98/yr</div>
            <span class="dash-activity-time">3d ago</span>
          </div>
          <div class="dash-activity-item">
            <div class="dash-activity-icon">📬</div>
            <div class="dash-activity-body"><strong>Admiral Insurance</strong> — auto-renewal letter parsed</div>
            <span class="dash-activity-time">5d ago</span>
          </div>
          <div class="dash-activity-item">
            <div class="dash-activity-icon">📋</div>
            <div class="dash-activity-body"><strong>weekly digest</strong> — issued with 3 actions</div>
            <span class="dash-activity-time">1w ago</span>
          </div>
        </div>
      </div>

      <div class="dash-card" style="margin-top:24px;">
        <div class="dash-card-header">connected inboxes</div>
        <div class="dash-inboxes">
          <div class="dash-inbox-item">
            <div class="dash-inbox-icon">📧</div>
            <div><strong>you@gmail.com</strong><span class="dash-inbox-meta">12 forward rules · active since jun</span></div>
            <span class="dash-inbox-status active">active</span>
          </div>
          <div class="dash-inbox-item">
            <div class="dash-inbox-icon">📧</div>
            <div><strong>hello@perch.app</strong><span class="dash-inbox-meta">4 forward rules · active since jul</span></div>
            <span class="dash-inbox-status" style="background:var(--panel);color:var(--text-dim);">idle</span>
          </div>
        </div>
        <button class="dash-add-inbox" style="margin-top:12px;">+ connect another inbox</button>
      </div>
    </div>
  </div>
</section>

</div>

<script>
(function() {
  var gate = document.getElementById('dashGate');
  var content = document.getElementById('dashContent');
  var form = document.getElementById('dashGateForm');
  var msg = document.getElementById('dashGateMsg');
  var pass = document.getElementById('dashPass');

  var PASSWORD = 'perchdemo';
  var COOKIE_KEY = 'perch_dash_auth';

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? match[2] : null;
  }

  function setCookie(name, value, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 86400000);
    document.cookie = name + '=' + value + ';path=/;expires=' + d.toUTCString() + ';SameSite=Lax';
  }

  if (getCookie(COOKIE_KEY) === '1') {
    unlock();
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (pass.value.trim() === PASSWORD) {
      setCookie(COOKIE_KEY, '1', 30);
      unlock();
    } else {
      msg.style.display = 'block';
      pass.value = '';
    }
  });

  function unlock() {
    gate.style.display = 'none';
    content.style.display = 'block';
  }

  var now = new Date();
  var hour = now.getHours();
  var greeting = hour < 12 ? 'good morning.' : hour < 17 ? 'good afternoon.' : 'good evening.';
  document.getElementById('dashGreeting').textContent = greeting;
})();
</script>

<%- include('partials/footer') %>
