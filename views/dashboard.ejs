<%- include('partials/head', { title: 'dashboard', metaDesc: 'your perch. dashboard — track renewals, savings, and actionable items across your accounts.' }) %>
<%- include('partials/nav') %>

<div class="page" id="main-content" role="main">

<section class="dash-page" id="dashPage">
  <div class="wrap" style="padding-top:120px;padding-bottom:20px;">
    <div class="dash-gate" id="dashGate">
      <div class="dash-gate-inner">
        <div class="dash-gate-icon">🔐</div>
        <h3 class="dash-gate-title">enter your demo pass</h3>
        <p class="dash-gate-hint">type <strong>perchdemo</strong> to see what your dashboard could look like.</p>
        <form id="dashGateForm" style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;max-width:360px;margin:0 auto;">
          <input type="password" id="dashPass" placeholder="password" autocomplete="off" style="flex:1;min-width:180px;padding:10px 14px;border-radius:8px;border:1px solid var(--line-strong);background:var(--bg);color:var(--text);font-size:13px;outline:none;font-family:var(--sans);" required>
          <button type="submit" class="btn-primary" style="padding:10px 20px;font-size:13px;">enter</button>
        </form>
        <p id="dashGateMsg" style="display:none;font-size:12px;color:#fca5a5;margin-top:10px;">incorrect password — try again</p>
      </div>
    </div>

    <div class="dash-content" id="dashContent" style="display:none;">
      <div class="dash-header">
        <div>
          <div class="dash-greeting" id="dashGreeting">good morning.</div>
          <div class="dash-subtitle">welcome back to your dashboard.</div>
        </div>
        <div class="dash-header-meta">
          <span class="dash-meta-badge">last synced 2 min ago</span>
          <span class="dash-meta-badge" style="background:rgba(74,222,128,0.1);color:#86efac;">■ online</span>
        </div>
      </div>

      <div class="dash-stats">
        <div class="dash-stat">
          <div class="dash-stat-icon">📬</div>
          <div class="dash-stat-num" data-count="127">127</div>
          <div class="dash-stat-label">emails processed</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon">💰</div>
          <div class="dash-stat-num" data-count="1431">£1,431</div>
          <div class="dash-stat-label">savings identified</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon">📅</div>
          <div class="dash-stat-num" data-count="4">4</div>
          <div class="dash-stat-label">renewing this month</div>
        </div>
        <div class="dash-stat">
          <div class="dash-stat-icon">⚡</div>
          <div class="dash-stat-num" data-count="3">3</div>
          <div class="dash-stat-label">need action</div>
        </div>
      </div>

      <div class="dash-grid">
        <div class="dash-card">
          <div class="dash-card-header">upcoming renewals</div>
          <div class="dash-timeline">
            <div class="dash-tl-item">
              <div class="dash-tl-dot dash-tl-dot-urgent"></div>
              <div class="dash-tl-body"><strong>Virgin Media Broadband</strong><span class="dash-tl-meta">£42/mo · 12 days</span></div>
              <span class="dash-tl-badge urgent">renegotiate</span>
            </div>
            <div class="dash-tl-item">
              <div class="dash-tl-dot dash-tl-dot-cancel"></div>
              <div class="dash-tl-body"><strong>PureGym Manchester</strong><span class="dash-tl-meta">£32/mo · 23 days</span></div>
              <span class="dash-tl-badge cancel">cancel</span>
            </div>
            <div class="dash-tl-item">
              <div class="dash-tl-dot dash-tl-dot-ok"></div>
              <div class="dash-tl-body"><strong>Namecheap domain</strong><span class="dash-tl-meta">£14.99/yr · 27 days</span></div>
              <span class="dash-tl-badge ok">renew</span>
            </div>
            <div class="dash-tl-item">
              <div class="dash-tl-dot dash-tl-dot-urgent"></div>
              <div class="dash-tl-body"><strong>Admiral Car Insurance</strong><span class="dash-tl-meta">£612.40/yr · 42 days</span></div>
              <span class="dash-tl-badge urgent">renegotiate</span>
            </div>
          </div>
        </div>

        <div class="dash-card">
          <div class="dash-card-header">monthly savings breakdown</div>
          <div class="dash-chart">
            <div class="dash-chart-bars">
              <div class="dash-chart-group">
                <div class="dash-chart-bar-wrap"><div class="dash-chart-bar" style="height:72px;"><span class="dash-chart-val">£124</span></div></div>
