              <div class="dash-chart-group">
                <div class="dash-chart-bar-wrap"><div class="dash-chart-bar" style="height:64px;"><span class="dash-chart-val">£112</span></div></div>
                <span class="dash-chart-label">apr</span>
              </div>
              <div class="dash-chart-group">
                <div class="dash-chart-bar-wrap"><div class="dash-chart-bar" style="height:108px;"><span class="dash-chart-val">£192</span></div></div>
                <span class="dash-chart-label">may</span>
              </div>
              <div class="dash-chart-group">
                <div class="dash-chart-bar-wrap"><div class="dash-chart-bar" style="height:140px;"><span class="dash-chart-val">£239</span></div></div>
                <span class="dash-chart-label dash-chart-label-active">jun</span>
              </div>
              <div class="dash-chart-group">
                <div class="dash-chart-bar-wrap"><div class="dash-chart-bar dash-chart-bar-projected" style="height:120px;"><span class="dash-chart-val">£208</span></div></div>
                <span class="dash-chart-label">jul*</span>
              </div>
            </div>
