<%- include('partials/head', { title: '' }) %>
<%- include('partials/nav') %>

<div class="page">
<section class="hero">
  <div class="wrap hero-inner">
    <div class="a-stagger">
      <div class="eyebrow">Built for the UK</div>
      <h1>Stop paying for things <em>you forgot you agreed to.</em></h1>
      <p class="hero-sub">perch. is an AI inbox for everything that quietly auto-renews — insurance, broadband, domains, subscriptions, contracts. Forward an email or upload a document. Get a date, an amount, and a verdict.</p>
      <div class="hero-cta-row">
        <a href="/waitlist" class="btn-primary">
          Join the waitlist →
        </a>
        <span class="hero-microcopy">No bank linking. No auto-cancel bots. Just visibility.</span>
      </div>
      <div class="stat-badge">
        <span class="stat-dot"></span>
        <span><strong>200+</strong> households and businesses already tracking renewals</span>
      </div>
    </div>
    <div class="hero-visual a-stagger">
      <div class="stage">
        <div class="flow-a">
          <div class="flow-item email">
            <div class="ftitle">Fwd: Your policy renews soon</div>
            <div class="fmeta"><span>Admiral Car Insurance</span><span class="tag">PDF</span></div>
          </div>
          <div class="flow-item card">
            <div class="ftitle">Admiral — Car Insurance</div>
            <div class="fmeta"><span>£612.40 / year</span><span>Renews 14 Aug</span></div>
          </div>
          <div class="verdict-tag renegotiate">Renegotiate — price up 22%</div>
          <div class="verdict-ring renegotiate"></div>
        </div>
        <div class="flow-b">
          <div class="flow-item email">
            <div class="ftitle">Fwd: Your subscription ends</div>
            <div class="fmeta"><span>Adobe Creative Cloud</span><span class="tag">Invoice</span></div>
          </div>
          <div class="flow-item card">
            <div class="ftitle">Adobe — Creative Cloud</div>
            <div class="fmeta"><span>£59.99 / month</span><span>Renews 3 Sep</span></div>
          </div>
          <div class="verdict-tag cancel">Cancel — unused for 4 months</div>
          <div class="verdict-ring cancel"></div>
        </div>
        <div class="stage-caption">forward it. we extract it. you decide.</div>
      </div>
    </div>
  </div>
</section>
</div>

<%- include('partials/footer') %>
