<script>
(function(){
  var testimonials = document.querySelectorAll('.testimonial');
  if (testimonials.length < 2) return;
  var current = 0;
  var dotsDiv = document.getElementById('testimonialDots');
  testimonials.forEach(function(t, i) {
    var dot = document.createElement('button');
    dot.style.cssText = 'width:8px;height:8px;border-radius:50%;border:1px solid var(--fog);background:' + (i === 0 ? 'var(--ember)' : 'transparent') + ';cursor:pointer;padding:0;transition:background 0.2s var(--ease);';
    dot.setAttribute('aria-label', 'Testimonial ' + (i + 1));
    dot.onclick = function() { showCard(i); resetTimer(); };
    dotsDiv.appendChild(dot);
  });
  var timer;
  function showCard(i) {
    testimonials.forEach(function(t, j) { t.style.display = j === i ? '' : 'none'; });
    dotsDiv.querySelectorAll('button').forEach(function(d, j) {
      d.style.background = j === i ? 'var(--ember)' : 'transparent';
    });
    current = i;
  }
  function next() { showCard((current + 1) % testimonials.length); }
  function resetTimer() { clearInterval(timer); timer = setInterval(next, 8000); }
  timer = setInterval(next, 8000);
  var section = document.getElementById('proof');
  if (section) {
    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) { if (!timer) timer = setInterval(next, 8000); }
      else { clearInterval(timer); timer = null; }
    }, { threshold: 0.1 });
    observer.observe(section);
  }
})();
</script>

