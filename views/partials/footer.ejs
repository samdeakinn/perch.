<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="logo">perch<span>.</span></div>
      <p class="footer-tagline">track what renews. decide what stays.</p>
    </div>
    <div class="footer-col">
      <h4>product</h4>
      <a href="/app">app</a>
      <a href="/demo">demo</a>
      <a href="/pricing">pricing</a>
      <a href="/features">features</a>
      <a href="/download">download</a>
      <a href="/roadmap">roadmap</a>
      <a href="/changelog">changelog</a>
    </div>
    <div class="footer-col">
      <h4>learn</h4>
      <a href="/problem">the problem</a>
      <a href="/how-it-works">how it works</a>
      <a href="/blog">blog</a>
      <a href="/resources">resources</a>
      <a href="/about">about</a>
      <a href="/privacy">privacy</a>
      <a href="/terms">terms</a>
    </div>
  </div>

  <div style="max-width:var(--max-body);margin:24px auto 0;padding:0 100px;">
    <div style="border-top:1px solid var(--mist);padding-top:20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <div style="font-size:12px;color:var(--dust);">get updates on auto-renewal, loyalty penalties, and perch. launch news.</div>
      <form id="footerSubscribe" style="display:flex;gap:6px;max-width:340px;">
        <input type="email" id="footerEmail" placeholder="you@email.com" required style="flex:1;min-width:180px;padding:8px 12px;border-radius:var(--radius-pill);border:1px solid var(--fog);background:var(--slate);color:var(--paper);font-size:12px;outline:none;font-family:var(--sans);">
        <button type="submit" style="padding:8px 14px;border-radius:var(--radius-pill);border:none;background:var(--ember);color:var(--obsidian);font-weight:500;font-size:12px;cursor:pointer;white-space:nowrap;font-family:var(--sans);">subscribe</button>
      </form>
      <div id="footerSubMsg" style="display:none;font-size:12px;color:var(--ember);">you're subscribed.</div>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-bottom-text">&copy; 2026 perch. &middot; <a href="/privacy" style="color:inherit;">privacy</a> &middot; <a href="/terms" style="color:inherit;">terms</a> &middot; <a href="/contact" style="color:inherit;">contact</a></span>
    <div style="display:flex;gap:16px;align-items:center;">
      <a href="https://x.com/perch_app" target="_blank" rel="noopener" style="font-size:11px;color:var(--dust);">x</a>
      <span class="footer-bottom-text" id="pageViewCounter" style="display:none;"></span>
    </div>
  </div>
</footer>

<button class="back-to-top" id="backToTop" aria-label="Back to top">&uarr;</button>
<div class="cursor-dot" id="cursorDot"></div>

<script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
<script src="/motion.js?v=2"></script>

<script>
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js');
}

(function() {
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Nav scroll
  var nav = document.getElementById('nav');
  window.addEventListener('scroll', function() {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Hamburger menu
  var hamburger = document.getElementById('hamburgerBtn');
  var overlay = document.getElementById('navOverlay');
  var overlayClose = document.getElementById('navOverlayClose');
  if (hamburger && overlay && overlayClose) {
    hamburger.addEventListener('click', function() { overlay.classList.add('open'); });
    overlayClose.addEventListener('click', function() { overlay.classList.remove('open'); });
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) overlay.classList.remove('open');
    });
  }

  // Footer subscribe
  document.getElementById('footerSubscribe')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('footerEmail').value.trim();
    if (!email) return;
    try {
      var r = await fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: 'Subscriber', email: email, segment: 'household', source: 'footer' }) });
      var d = await r.json();
      this.style.display = 'none';
      var msg = document.getElementById('footerSubMsg');
      msg.textContent = d.ok ? (d.existing ? 'you\'re already subscribed.' : 'subscribed.') : 'error — try again.';
      msg.style.display = 'block';
    } catch(_) { this.style.display = 'none'; document.getElementById('footerSubMsg').style.display = 'block'; }
  });

  // Button ripple
  document.querySelectorAll('.btn-primary').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      var rect = this.getBoundingClientRect();
      var ripple = document.createElement('span');
      var size = Math.max(rect.width, rect.height);
      var x = e.clientX - rect.left - size / 2;
      var y = e.clientY - rect.top - size / 2;
      ripple.style.cssText = 'width:' + size + 'px;height:' + size + 'px;left:' + x + 'px;top:' + y + 'px;';
      ripple.className = 'btn-ripple';
      this.appendChild(ripple);
      ripple.addEventListener('animationend', function() { ripple.remove(); });
    });
  });

  // Back to top
  var backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', function() { backBtn.classList.toggle('visible', window.scrollY > 500); }, { passive: true });
    backBtn.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });
  }

  // FAQ toggles
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.addEventListener('click', function() { item.classList.toggle('open'); });
  });

  // Counter anims
  document.querySelectorAll('.proof-num[data-count], .stat-block-num[data-count]').forEach(function(el) {
    var target = parseInt(el.getAttribute('data-count'), 10);
    var isCurrency = el.textContent.includes('\u00A3');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        observer.unobserve(el);
        var dur = 1500, start = performance.now();
        function tick(now) {
          var t = Math.min((now - start) / dur, 1);
          var eased = 1 - Math.pow(1 - t, 3);
          var val = Math.round(eased * target) || 0;
          el.textContent = isCurrency ? '\u00A3' + val.toLocaleString() : val.toLocaleString();
          if (t < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.5 });
    observer.observe(el);
  });

  // Waitlist form (used on waitlist page)
  var form = document.getElementById('waitlistForm');
  var formSuccess = document.getElementById('formSuccess');
  if (form && formSuccess) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var name = document.getElementById('name').value.trim();
      var email = document.getElementById('email').value.trim();
      if (!name || !email) return;
      try {
        var segment = (document.querySelector('.ob-segment-card.selected')?.getAttribute('data-segment')) || 'household';
        await fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, email: email, segment: segment }) });
      } catch (_) {}
      form.style.display = 'none';
      formSuccess.classList.add('show');
    });
  }

  // Waitlist count
  fetch('/api/waitlist/count', { cache: 'no-store' }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.ok && d.count > 0) {
      var badge = document.getElementById('waitlistCount');
      if (badge) { badge.textContent = d.count.toLocaleString(); badge.style.display = 'inline'; }
    }
  }).catch(function() {});

  // Page view counter
  fetch('/api/views', { cache: 'no-store' }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.ok && d.views > 0) {
      var pv = document.getElementById('pageViewCounter');
      if (pv) { pv.textContent = d.views.toLocaleString() + ' page views · no cookies, no tracking'; pv.style.display = 'block'; }
    }
  }).catch(function() {});

  // Cookie consent
  try {
    if (!localStorage.getItem('cookieConsent')) {
      var bar = document.createElement('div');
      bar.id = 'cookieBar';
      bar.style.cssText = 'position:fixed;bottom:0;left:0;right:0;z-index:100;padding:14px 20px;background:var(--graphite);border-top:1px solid var(--mist);font-size:13px;color:var(--pencil);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;backdrop-filter:blur(12px);';
      bar.innerHTML = '<span>perch. uses only essential cookies for site function. no tracking, no profiling, no sharing.</span><button id="cookieDismiss" style="white-space:nowrap;padding:8px 16px;border-radius:8px;border:1px solid var(--fog);background:none;color:var(--paper);font-size:12px;cursor:pointer;font-family:var(--sans);font-weight:500;">got it</button>';
      document.body.appendChild(bar);
      document.getElementById('cookieDismiss').addEventListener('click', function() {
        bar.style.transform = 'translateY(100%)';
        bar.style.transition = 'transform .4s cubic-bezier(0.4, 0, 0.2, 1)';
        try { localStorage.setItem('cookieConsent', '1'); } catch(e) {}
      });
    }
  } catch(e) {}
})();
</script>
</body>
</html>
